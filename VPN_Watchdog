#!/bin/sh
# Автоустановщик Watchdog-VPN v6 (Анти-флуд + Тайминги)

cat << 'EOF' > /etc/watchdog-vpn.sh
#!/bin/sh

FLAG_FILE="/tmp/vpn_down_by_watchdog"
STALL_FLAG="/tmp/vpn_stalled_once"
LOCK_FILE="/tmp/watchdog_running.lock"

# Защита от дублирования (если скрипт завис, не запускаем второй)
if [ -f "$LOCK_FILE" ]; then exit 0; fi
touch "$LOCK_FILE"

kill_vpn() {
    logger -t VPN-Watchdog "VPN заблокирован! Возвращаем обычный интернет."
    /etc/init.d/podkop stop
    uci del dhcp.@dnsmasq[0].server >/dev/null 2>&1
    uci set dhcp.@dnsmasq[0].noresolv='0'
    uci commit dhcp
    /etc/init.d/dnsmasq restart
    ip route add unreachable 198.18.0.0/15 >/dev/null 2>&1
    date +%s > "$FLAG_FILE"
    rm -f "$STALL_FLAG"
}

check_tunnel() {
    # Увеличили таймаут curl до 10 секунд, чтобы дать списку загрузиться
    HTTP_CODE=$(curl -s -m 10 -o /dev/null -w "%{http_code}" -x socks5h://127.0.0.1:4534 http://www.gstatic.com/generate_204)
    [ "$HTTP_CODE" = "204" ] && return 0 || return 1
}

if pidof sing-box >/dev/null; then
    if check_tunnel; then
        ip route del unreachable 198.18.0.0/15 >/dev/null 2>&1
        rm -f "$STALL_FLAG"
    else
        if ping -c 2 -W 2 8.8.8.8 >/dev/null 2>&1; then
            if [ -f "$STALL_FLAG" ]; then
                kill_vpn
            else
                logger -t VPN-Watchdog "Туннель завис. Рестарт Podkop (ждем 40 сек)..."
                /etc/init.d/podkop restart
                touch "$STALL_FLAG"
                sleep 40 # Даем списку обхода время на загрузку
            fi
        fi
    fi
else
    if [ -f "$FLAG_FILE" ]; then
        LAST_KILL=$(cat "$FLAG_FILE")
        NOW=$(date +%s)
        if [ $((NOW - LAST_KILL)) -gt 300 ]; then
            logger -t VPN-Watchdog "Пробуем восстановить туннель..."
            ip route del unreachable 198.18.0.0/15 >/dev/null 2>&1
            /etc/init.d/podkop start
            sleep 40 
            if check_tunnel; then
                logger -t VPN-Watchdog "VPN восстановлен!"
                rm -f "$FLAG_FILE" "$STALL_FLAG"
            else
                kill_vpn
            fi
        fi
    fi
fi

rm -f "$LOCK_FILE"
EOF

chmod +x /etc/watchdog-vpn.sh
sync
