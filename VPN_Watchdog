#!/bin/sh
# Автоустановщик Watchdog-VPN v2 (Умный рестарт + Проверка TCP)

echo "Установка Умного Watchdog v2..."

cat << 'EOF' > /etc/watchdog-vpn.sh
#!/bin/sh

FLAG_FILE="/tmp/vpn_down_by_watchdog"
STALL_FLAG="/tmp/vpn_stalled_once"

kill_vpn() {
    logger -t VPN-Watchdog "VPN заблокирован! Возвращаем обычный интернет."
    /etc/init.d/podkop stop
    uci del dhcp.@dnsmasq[0].server >/dev/null 2>&1
    uci set dhcp.@dnsmasq[0].noresolv='0'
    uci commit dhcp
    /etc/init.d/dnsmasq restart
    date +%s > "$FLAG_FILE"
}

# 1. Проверяем, жив ли процесс ядра
if pgrep sing-box >/dev/null; then
    # 2. Жесткая проверка: качаем данные прямо через туннель
    if env http_proxy="http://127.0.0.1:4534" https_proxy="http://127.0.0.1:4534" wget -q -O /dev/null -T 5 http://ya.ru; then
        # Трафик идет, всё отлично
        rm -f "$STALL_FLAG"
    else
        # Трафик не идет. Проверяем, есть ли вообще интернет от провайдера
        if ping -c 2 -W 2 8.8.8.8 >/dev/null 2>&1; then
            if [ -f "$STALL_FLAG" ]; then
                # Если уже пытались перезапускать, и не помогло - значит это жесткая блокировка
                kill_vpn
                rm -f "$STALL_FLAG"
            else
                # Типичное "тихое зависание" VLESS. Делаем быстрый рестарт!
                logger -t VPN-Watchdog "Туннель завис. Делаем быстрый рестарт Podkop..."
                /etc/init.d/podkop restart
                touch "$STALL_FLAG"
            fi
        fi
    fi
else
    # 3. Если VPN отключен нами, проверяем таймер на 5 минут
    if [ -f "$FLAG_FILE" ]; then
        LAST_KILL=$(cat "$FLAG_FILE")
        NOW=$(date +%s)
        if [ $((NOW - LAST_KILL)) -gt 300 ]; then
            logger -t VPN-Watchdog "5 минут прошло. Пробуем восстановить туннель..."
            /etc/init.d/podkop start
            sleep 25
            if env http_proxy="http://127.0.0.1:4534" https_proxy="http://127.0.0.1:4534" wget -q -O /dev/null -T 5 http://ya.ru; then
                logger -t VPN-Watchdog "VPN успешно восстановлен!"
                rm -f "$FLAG_FILE"
                rm -f "$STALL_FLAG"
            else
                logger -t VPN-Watchdog "Сервер все еще заблокирован. Отключаем."
                kill_vpn
            fi
        fi
    fi
fi
EOF

chmod +x /etc/watchdog-vpn.sh

if uci show podkop >/dev/null 2>&1; then
    uci set podkop.settings.shutdown_correctly='1'
    uci commit podkop
fi

sed -i '/watchdog-vpn.sh/d' /etc/crontabs/root
echo "*/3 * * * * /etc/watchdog-vpn.sh" >> /etc/crontabs/root
/etc/init.d/cron restart

if ! grep -q "/etc/watchdog-vpn.sh" /etc/sysupgrade.conf; then
    echo "/etc/watchdog-vpn.sh" >> /etc/sysupgrade.conf
fi

sync
echo "Готово! Watchdog v2 установлен и запущен."
