#!/bin/sh
# Автоустановщик Watchdog-VPN v5 (SOCKS5 + Curl Probe)

echo "Установка Умного Watchdog v5..."

cat << 'EOF' > /etc/watchdog-vpn.sh
#!/bin/sh

FLAG_FILE="/tmp/vpn_down_by_watchdog"
STALL_FLAG="/tmp/vpn_stalled_once"

# Убеждаемся, что установлена профессиональная утилита curl
if ! command -v curl >/dev/null 2>&1; then
    logger -t VPN-Watchdog "Установка curl для точных проверок..."
    apk add curl >/dev/null 2>&1 || opkg install curl >/dev/null 2>&1
fi

kill_vpn() {
    logger -t VPN-Watchdog "VPN заблокирован! Возвращаем обычный интернет."
    /etc/init.d/podkop stop
    uci del dhcp.@dnsmasq[0].server >/dev/null 2>&1
    uci set dhcp.@dnsmasq[0].noresolv='0'
    uci commit dhcp
    /etc/init.d/dnsmasq restart
    
    # Сбрасываем кэш на устройствах
    ip route add unreachable 198.18.0.0/15 >/dev/null 2>&1
    
    date +%s > "$FLAG_FILE"
    rm -f "$STALL_FLAG"
}

check_tunnel() {
    # Жестко пускаем трафик через SOCKS5 порт туннеля (никаких обходов!)
    HTTP_CODE=$(curl -s -m 5 -o /dev/null -w "%{http_code}" -x socks5h://127.0.0.1:4534 http://www.gstatic.com/generate_204)
    
    if [ "$HTTP_CODE" = "204" ]; then
        return 0 # Успех, трафик прошел через VPN
    else
        return 1 # Провал (сервер недоступен)
    fi
}

# --- ОСНОВНАЯ ЛОГИКА ---
if pidof sing-box >/dev/null; then
    if check_tunnel; then
        ip route del unreachable 198.18.0.0/15 >/dev/null 2>&1
        rm -f "$STALL_FLAG"
    else
        if ping -c 2 -W 2 8.8.8.8 >/dev/null 2>&1; then
            if [ -f "$STALL_FLAG" ]; then
                kill_vpn
            else
                logger -t VPN-Watchdog "Туннель завис. Делаем быстрый рестарт..."
                /etc/init.d/podkop restart
                touch "$STALL_FLAG"
            fi
        fi
    fi
else
    if [ -f "$FLAG_FILE" ]; then
        LAST_KILL=$(cat "$FLAG_FILE")
        NOW=$(date +%s)
        if [ $((NOW - LAST_KILL)) -gt 300 ]; then
            logger -t VPN-Watchdog "5 минут прошло. Пробуем восстановить туннель..."
            ip route del unreachable 198.18.0.0/15 >/dev/null 2>&1
            /etc/init.d/podkop start
            sleep 25
            
            if check_tunnel; then
                logger -t VPN-Watchdog "VPN успешно восстановлен!"
                rm -f "$FLAG_FILE"
                rm -f "$STALL_FLAG"
            else
                logger -t VPN-Watchdog "Сервер все еще заблокирован. Отключаем обратно."
                kill_vpn
            fi
        fi
    fi
fi
EOF

chmod +x /etc/watchdog-vpn.sh

if uci show podkop >/dev/null 2>&1; then
    uci set podkop.settings.shutdown_correctly='1'
    uci commit podkop
fi

sed -i '/watchdog-vpn.sh/d' /etc/crontabs/root
echo "*/3 * * * * /etc/watchdog-vpn.sh" >> /etc/crontabs/root
/etc/init.d/cron restart

if ! grep -q "/etc/watchdog-vpn.sh" /etc/sysupgrade.conf; then
    echo "/etc/watchdog-vpn.sh" >> /etc/sysupgrade.conf
fi

sync
echo "Готово! Умный Watchdog v5 установлен."
